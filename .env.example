# ─────────────────────────────────────────────────────────────────────────────
# BloodChain DApp — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer wallet ───────────────────────────────────────────────────────────
# Private key of the wallet used for deployment (without 0x prefix).
# This account becomes the owner/admin of all contracts.
# Use a dedicated deployer wallet, never your main personal wallet.
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ── Alchemy RPC endpoints ─────────────────────────────────────────────────────
# Sign up at https://alchemy.com and create an app for each network.
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# ── Etherscan API key (for contract verification) ─────────────────────────────
# Obtain from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key
